   "source": [
    "sent_tokenizer = PunktSentenceTokenizer()\n",
    "\n",
    "dataset[\"preproc_sentences\"] =\\\n",
    "      dataset[\"text\"].map(lambda content : [main_pipeline(sentence,\n",
    "                                                            print_output=False,\n",
