    "# Define comparisons\n",
    "comparisons = {\n",
    "    \"Vader VS Stars\": (\"normalized_polarity_vader\", \"normalized_score\"),\n",
    "    \"Vader (mean sentences) VS Stars\": (\"normalized_polarity_vader_mean_sentences\", \"normalized_score\"),\n",
    "    \"TextBlob VS Stars\": (\"normalized_polarity_textblob\", \"normalized_score\"),\n",
    "    \"TextBlob (mean sentences) VS Stars\": (\"normalized_polarity_textblob_mean_sentences\", \"normalized_score\"),\n",
    "    \"Vader vs TextBlob\": (\"normalized_polarity_vader\", \"normalized_polarity_textblob\")\n",
    "}\n",
    "\n",
    "metrics = {}\n",
    "\n",
    "# Compute metrics\n",
    "for name, (pred_name, true_name) in comparisons.items():\n",
    "    y_pred = globals()[pred_name].reshape(-1)\n",
    "    y_true = globals()[true_name].reshape(-1)\n",
    "\n",
    "    pearson_r, _ = pearsonr(y_true, y_pred)\n",
    "    rmse = mean_squared_error(y_true, y_pred, squared=False)  # RMSE\n",
    "    mape = mean_absolute_percentage_error(y_true + 1, y_pred + 1)  # avoid division by zero\n",
    "\n",
    "    metrics[name] = {\n",
    "        \"Pearson R\": round(pearson_r, 3),\n",
    "        \"RMSE\": round(rmse, 3),\n",
    "        \"MAPE\": round(mape, 3)\n",
    "    }\n",
    "\n",
    "# Convert to DataFrame\n",
    "metrics_df = pd.DataFrame(metrics)\n",
    "metrics_df\n"
   ]
  },
